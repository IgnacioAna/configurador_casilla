# Variables de entorno del Configurador Impacar (Vite — prefijo VITE_ obligatorio).
# Copie este archivo y defina los valores según el entorno. NINGUNA es obligatoria:
# si no se define, la app usa el número de PRUEBAS por defecto (ver src/data/contacto.js).

# Número de WhatsApp de destino del link wa.me (SOLO dígitos: 54 + 9 + número, sin '+' ni espacios).
# Demo/pruebas (default si se omite): 5492954555113  (Ignacio)
# PRODUCCIÓN (swap antes del go-live, definir en .env.production): 5492302468754  (Impacar — General Pico)
VITE_WA_NUMBER=5492954555113

# Texto legible del WhatsApp que se muestra en el contacto del PDF (opcional; default en contacto.js).
VITE_WA_DISPLAY=+54 9 2954 55-5113
